{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Papr",
  "version": "0.8.0",
  "identifier": "com.thomas.papr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Papr",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 560,
        "backgroundColor": "#FBF9F3",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 13, "y": 19 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["papr"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/l0ng-ai/papr/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4OTJBNjkzOERCREFEMUUKUldRZXJiMk5rNmFTcUpDQnFPMi9CSmJwajFTcURiL2szd2lXenEyRHdKWmVGN1VFZGNxQXpUeEIK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "News",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
